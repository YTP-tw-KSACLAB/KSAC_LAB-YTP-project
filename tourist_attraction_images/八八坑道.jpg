l],[\"$\",\"$Ld\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$e\",null,{\"fallback\":null,\"children\":\"$Lf\"}]}]}]]}],false]],\"m\":\"$undefined\",\"G\":[\"$10\",[]],\"s\":false,\"S\":false}\n"])</script><script>self.__next_f.push([1,"13:Tb4a,"])</script><script>self.__next_f.push([1,"打造淡季旅遊與主題性等旅遊商品規劃\u003cbr/\u003e辦理永續觀光說明會，並輔導食、宿、遊、購、行業者取得國際永續旅遊相關認證\u003cbr/\u003e拓展觀光圈旅遊平台通路及上架\u003cbr/\u003e配合「國際藝術島」辦理主題式行銷\u003cbr/\u003e預計完成馬祖觀光資源（食、宿、遊、購、行）盤點\u003cbr/\u003e持續辦理島嶼學院@馬祖\u003cbr/\u003e持續辦理服務品質提升計畫，針對業者進行服務品質診斷，改善店家空間氛圍營造\u003cbr/\u003e舉辦馬祖美食節-馬祖特色食材料理比賽\u003cbr/\u003e馬祖觀光圈與其他12管理處觀光圈進行品牌跨域共享\u003cbr/\u003e相關觀光圈媒體宣傳於平面雜誌或FB、IG等露出及拍攝主題宣傳影片等\u003cbr/\u003e馬祖觀光資訊平台優化，提供中英日韓四國語言\u003cbr/\u003e完成15家伴手禮包裝改善\u003cbr/\u003e馬祖觀光圈品牌視覺設計及應用\u003cbr/\u003e編印馬祖美食手冊\u003cbr/\u003e輔導旅宿業者申請好客民宿甄選\u003cbr/\u003e宣傳紀念品製作\u003cbr/\u003e輔導4家業者申請GTS國際永續旅遊認證（2家獲得二星認證、2家獲得一星認證）\u003cbr/\u003e與觀光署福州辦事處合作辦理推介會\u003cbr/\u003e拍攝中、英、日、韓、閩東語版國際宣傳影片\u003cbr/\u003e帶領觀光圈業者參加112年美食展及ITF國際旅展\u003cbr/\u003e112年與華信航空合作，協助馬祖國際藝術島行銷推廣，並同步宣傳馬祖觀光圈品牌（至少向20萬人次旅客行銷推廣）\u003cbr/\u003e設計3條第二屆馬祖國際藝術島特色遊程，並增加1,200人次參與，創造觀光產值約新臺幣1,500萬元\u003cbr/\u003e針對兩岸跨境遊、藍色公路及郵輪遊程，規劃3大類特色遊程，每類別針對不同客群另有規劃2至4種遊程\u003cbr/\u003e112年協助11家在地餐飲業者改善餐飲軟、硬體設施，並協助開發5道菜餚\u003cbr/\u003e協助觀光圈業者製作聯盟會員地圖並架設本專區，協助加入聯盟之業者行銷推廣\u003cbr/\u003e112年隨國境解封，廣邀國內外媒體、觀光業者蒞馬採線10團次\u003cbr/\u003e113年5月5日首度有新加坡團體旅遊遊客蒞馬旅遊，開創新南向國家客源\u003cbr/\u003e113年率10家馬祖觀光圈業者前往新加坡，開拓國際都會型旅遊市場客源\u003cbr/\u003e113年與華信、立榮航空及自媒體合作，協助推展馬祖觀光圈業者資訊達44篇\u003cbr/\u003e113年10月與長榮航空合作，於該航空全球航線、全艙等娛樂系統推展馬祖旅遊資訊，觀閱人次達108萬8,783人次\u003cbr/\u003e與舊山線鐵道自行車合作，於勝興車站設置馬祖觀光圈商品展售專櫃，協助推展馬祖特色產品並推動跨域共享\u003cbr/\u003e持續與高鐵假期合作，推動「搭高鐵遊馬祖」遊程，在馬高航線養客成功前，先行以高鐵、空運之跨運具整合自由行遊程模式，培養台灣南部客群\u003cbr/\u003e協助馬祖在地6家旅行社申請「環境部銅級環保旅行業標章」，預就生態旅遊推動加以整備"])</script><script>self.__next_f.push([1,"4:[\"$\",\"html\",null,{\"lang\":\"zh-TW\",\"children\":[\"$\",\"body\",null,{\"tabIndex\":-1,\"children\":[[\"$\",\"a\",null,{\"href\":\"#main-content\",\"className\":\"skip-link\",\"children\":\"跳到主要內容區\"}],[\"$\",\"$L11\",null,{}],[\"$\",\"$L12\",null,{\"locale\":\"zh-TW\",\"dict\":{\"MetaInfo\":{\"Title\":\"馬祖國家風景區觀光資訊網\",\"Author\":\"馬祖國家風景區管理處\",\"MetaDescription\":\"探索馬祖之美，東引燈塔日出、芹壁聚落石屋、鐵堡戰地記憶、蛇島燕鷗生態與坤坵沙灘方塊海，更不可錯過藍眼淚夜色。馬祖國家風景區管理處提供完整旅遊資訊，帶您體驗海島魅力。\",\"MetaCanonical\":\"https://www.matsu-nsa.gov.tw/\"},\"Common\":{\"Index\":\"首頁\",\"LastUpdated\":\"更新日期\",\"TotalCount\":\"共 {{count}} 筆結果\",\"Adjacent\":{\"Previous\":\"上一頁\",\"Next\":\"下一頁\",\"BackHome\":\"回列表\"},\"Filter\":\"篩選\",\"DateRange\":{\"Title\":\"日期區間\",\"Placeholder\":\"請選擇日期範圍\"},\"Clear\":\"清除\",\"Close\":\"關閉\",\"SearchButton\":\"查詢\",\"SearchPlaceholder\":\"請輸入關鍵字進行搜尋\",\"Category\":\"選擇類型\",\"Area\":\"選擇區域\",\"Sort\":\"排序\",\"OpenFilter\":\"展開篩選條件\",\"CloseFilter\":\"收合篩選條件\",\"SearchStatusLoading\":\"{{subject}}查詢中\",\"SearchStatusUpdated\":\"{{subject}}搜尋結果已更新，共 {{count}} 筆資料\",\"SearchStatusNoData\":\"{{subject}}搜尋結果已更新，目前沒有資料\",\"FilterSearchStatusUpdated\":\"查詢結果已更新，共 {{count}} 筆結果\",\"SeeMore\":\"看更多\",\"PageErrorReport\":\"網頁錯誤回報\",\"SelectTags\":\"選擇標籤\",\"RelatedPhotos\":\"相關照片\",\"SelectDays\":\"選擇天數\",\"RelatedLinks\":\"相關連結\",\"Attachments\":\"附件檔案\",\"EmptyData\":\"目前沒有資料\"},\"Homepage\":{\"AccessibleTitle\":\"馬祖國家風景區管理處 | 首頁\",\"Banner\":{\"birdMessage\":\"今日紫外線 指數高，外出 請做好防曬與 補充水分歐！\"},\"Info\":{\"Weather\":{\"Title\":\"氣象資訊\",\"Subtitle\":\"南竿氣象\",\"Temperature\":{\"Title\":\"氣溫\",\"Content\":\"18ºC\"},\"Fog\":{\"Title\":\"濃霧\",\"Content\":\"50 %\"},\"Rain\":{\"Title\":\"降雨\",\"Content\":\"10 %\"},\"UV\":{\"Title\":\"紫外線\",\"Content\":\"高量級\"},\"Air\":{\"Title\":\"空氣品質\",\"Content\":\"良好\"},\"Button\":\"更多資訊\"},\"Visit\":{\"Title\":\"智慧觀光情報\",\"Subtitle\":\"人流預警\",\"Status\":{\"Best\":\"順暢\",\"Medium\":\"稍擁\",\"Busy\":\"擁塞\"},\"Center\":{\"Nangan\":\"南竿遊客中心\",\"Began\":\"北竿遊客中心\",\"Dongyin\":\"東引遊客中心\",\"Dongju\":\"東莒遊客中心\"},\"Remark\":\"*本系統判斷方式採景點範圍人潮平均值概念\",\"Buttons\":{\"Tide\":\"潮汐資訊\",\"Control\":\"景區管制查詢\",\"Traffic\":\"交通查詢\"},\"TideUpdatedAt\":\"資料更新時間\",\"ControlUpdatedAt\":\"資料更新時間\",\"SpotManageModal\":{\"SectionTitle\":\"景區管制\",\"SectionIntro\":\"陣風達10級（含）以上或長浪發生時，以下景區則關閉：\",\"Source\":\"資料來源（交通部中央氣象署）\",\"MoreInfo\":\"更多坑道訊息\",\"CaveTitle\":\"坑道時間\",\"CaveHeaderArea\":\"南竿鄉\",\"CaveHeaderOpenHours\":\"開放時間\",\"CaveName\":\"北海坑道\",\"WindLevel\":\"風級\",\"StatusOpen\":\"開放\",\"StatusClose\":\"關閉\"},\"TideModal\":{\"Source\":\"潮汐資料來源為中央氣象署馬祖氣象站福澳港\",\"TableHeader\":{\"Type\":\"潮汐\",\"Time\":\"時間\",\"Height\":\"潮高\"},\"FallbackArea\":{\"Nangan\":\"南竿潮汐\",\"Began\":\"北竿潮汐\",\"Dongyin\":\"東引潮汐\",\"Dongju\":\"莒光潮汐\"},\"FallbackType\":{\"Low\":\"乾潮\",\"High\":\"滿潮\"}}}},\"Marquee\":[\"因早期軍事構工困難且近年推動通用化旅遊環境，為提升旅遊品質、調整步道階梯高度及級高均化，本處規劃辦理「114年北竿06及08據點廣場步道設施改善工程」，以期達到全齡友善空間。\",\"因早期軍事構工困難且近年推動通用化旅遊環境，為提升旅遊品質、調整步道階梯高度及級高均化，本處規劃辦理「114年北竿06及08據點廣場步道設施改善工程」，以期達到全齡友善空間。\",\"因早期軍事構工困難且近年推動通用化旅遊環境，為提升旅遊品質、調整步道階梯高度及級高均化，本處規劃辦理「114年北竿06及08據點廣場步道設施改善工程」，以期達到全齡友善空間。\"],\"News\":{\"Title\":\"最新消息\",\"List\":[{\"catagory\":\"一般公告\",\"date\":\"2025-03-06\",\"title\":\"114年南竿鄉媽祖巨神像船型平臺設施維護保養工程\"},{\"catagory\":\"一般公告\",\"date\":\"2025-03-06\",\"title\":\"114年南竿鄉媽祖巨神像船型平臺設施維護保養工程\"},{\"catagory\":\"一般公告\",\"date\":\"2025-03-06\",\"title\":\"114年南竿鄉媽祖巨神像船型平臺設施維護保養工程\"},{\"catagory\":\"一般公告\",\"date\":\"2025-03-06\",\"title\":\"114年南竿鄉媽祖巨神像船型平臺設施維護保養工程\"}],\"Button\":\"更多資訊\"},\"Event\":{\"Title\":\"最新活動\",\"Text\":\"「來去客庄尞」短影音徵件活動\"},\"Spot\":{\"Explore\":{\"Title\":\"探索馬祖的自然與人文奇觀\",\"Content\":\"探索獨特的海島風情與豐富的文化遺產，馬祖的必遊景點等你來發現！\"},\"Title\":\"必看景點\",\"Area\":{\"Began\":\"北竿\",\"Nangan\":\"南竿\",\"Dongyin\":\"東引\",\"Jukuang\":\"莒光\"},\"Adventure\":{\"Title\":\"島嶼的靜謐冒險\",\"Content\":\"沿著寧靜的海岸散步、穿梭戰地遺跡，感受北竿兼具自然與人文的低調魅力。\"}},\"Live\":{\"Title\":\"Live馬祖美景即時看\",\"Subtitle\":\"一覽四大島特色地質美景\",\"Location\":[],\"Button\":\"觀看即時影像\"},\"Travel\":{\"Title\":\"一趟旅程，看見馬祖的\u003cspan\u003e深度\u003c/span\u003e與\u003cspan\u003e靈魂\u003c/span\u003e\",\"Content\":\"一場深入島嶼記憶的旅程，從戰地遺跡、宗教廟宇、濱海風情與在地日常，帶你慢慢走進馬祖的文化、故事與生活節奏。\"},\"Recommend\":{\"Title\":\"推薦遊程\",\"Beach\":{