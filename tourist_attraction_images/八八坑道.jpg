/static/media/default-share-img.0ccfb077.webp\"}],[\"$\",\"meta\",null,{\"property\":\"og:url\",\"content\":\"https://www.matsu-nsa.gov.tw/zh-TW/announce\"}]]}],[\"$\",\"h1\",null,{\"className\":\"visually-hidden\",\"children\":\"馬祖國家風景區管理處 | 首頁\"}],[\"$\",\"$L1a\",null,{\"locale\":\"zh-TW\"}],[\"$\",\"$L1b\",null,{\"locale\":\"zh-TW\",\"dict\":\"$4:props:children:props:children:2:props:dict\"}],[\"$\",\"$L1c\",null,{\"locale\":\"zh-TW\"}],[\"$\",\"div\",null,{\"className\":\"home-latest\",\"children\":[\"$\",\"div\",null,{\"className\":\"container\",\"children\":[\"$\",\"div\",null,{\"className\":\"row\",\"children\":[[\"$\",\"div\",null,{\"className\":\"col-lg-6\",\"children\":[\"$\",\"$L1d\",null,{\"locale\":\"zh-TW\",\"dict\":\"$4:props:children:props:children:2:props:dict\"}]}],[\"$\",\"div\",null,{\"className\":\"col-lg-6\",\"children\":[\"$\",\"$L1e\",null,{\"locale\":\"zh-TW\",\"dict\":\"$4:props:children:props:children:2:props:dict\"}]}]]}]}]}],[\"$\",\"$L1f\",null,{\"locale\":\"zh-TW\",\"dict\":\"$4:props:children:props:children:2:props:dict\"}],[\"$\",\"$L20\",null,{\"locale\":\"zh-TW\",\"dict\":\"$4:props:children:props:children:2:props:dict\"}],[\"$\",\"$L21\",null,{\"dict\":\"$4:props:children:props:children:2:props:dict\"}],[\"$\",\"$L22\",null,{\"locale\":\"zh-TW\",\"dict\":\"$4:props:children:props:children:2:props:dict\"}],[\"$\",\"$L23\",null,{\"locale\":\"zh-TW\",\"dict\":\"$4:props:children:props:children:2:props:dict\"}],[\"$\",\"$L24\",null,{\"dict\":\"$4:props:children:props:children:2:props:dict\",\"instagramData\":[{\"id\":\"18067581578678912\",\"caption\":\"來一道必吃馬祖美食 #紅糟炒飯 😎\\n#影片為家庭日常版本\\n\\n這盤色澤超誘人的紅糟炒飯\\n可是馬祖餐桌上的常客\\n#紅糟 是釀造馬祖老酒後留下來的酒糟\\n當它一接觸到熱鍋\\n那股獨特的發酵香氣與微甜酒香瞬間撲鼻而來🔥\\n厲害的紅糟炒飯，必須炒得粒粒分明，鑊氣十足。 \\n每一顆白米飯都要均勻裹上漂亮的酒紅色\\n配上肉絲、雞蛋和蔥花大火快炒。 \\n吃起來沒有刺鼻的酒味，反而有一種溫潤醇厚的回甘\\n保證讓你一口接一口🤤\\n\\n大家還有什麼紅糟炒飯的私藏吃法嗎！歡迎跟小編分享～\",\"media_type\":\"VIDEO\",\"media_url\":\"$25\",\"permalink\":\"https://www.instagram.com/reel/DXgBAEIDAiP/\",\"timestamp\":\"2026-04-24T04:01:41+0000\"},{\"id\":\"18315222817259573\",\"caption\":\"四到六月的馬祖，總是帶著一層迷幻的霧氣🌫️\\n如果想找個不受天氣影響，又能感受震撼視覺的景點\\n來 #大漢據點 探險就對了！\\n\\n這裡可不是普通的單層山洞\\n它是當年國軍弟兄在花崗岩懸崖裡\\n硬生生開鑿出來的 三層樓立體坑道🤯\\n走在深邃陰涼的坑道裡\\n宛如走進真實版的地下迷宮，還自帶天然冷氣✨\\n\\n重點這裡超級好拍，各個角度都能拍出美照📷\\n下次去北海坑道， 記得多走幾步路\\n從裡到外好好感受一下\\n大漢據點這份屬於馬祖的硬派浪漫🔥\\n\\n#南竿 #馬祖旅遊\",\"media_type\":\"VIDEO\",\"media_url\":\"$26\",\"permalink\":\"https://www.instagram.com/reel/DXa4iwpgbvM/\",\"timestamp\":\"2026-04-22T04:11:41+0000\"},{\"id\":\"18020282561829431\",\"caption\":\"今天是二十四節氣的穀雨\\n雨水滋潤了百穀，也餵飽了大海🌧️\\n有經驗的追淚人都知道\\n「白天看赤潮，晚上看藍眼淚。」\\n\\n這幾天的雨水，將陸地上的營養沖刷入海\\n讓夜光蟲（藍眼淚）瘋狂繁殖聚集。 \\n白天看過去，海面像被倒了鐵鏽水一樣\\n這就是傳說中的 #赤潮 現象🍅\\n\\n別覺得它髒，這可是代表淚況即將炸裂的最高級警報🚨 \\n原本紅褐色的藻水，到了晚上受到浪潮拍打\\n就會瞬間變成整片螢光藍的銀河🌌\\n如果你今天在岸邊看到了這抹紅\\n恭喜你！大機率大景即將登場😎\\n\\n📷感謝影片來源： 九號公路上的貓 Route9 Photography\",\"media_type\":\"VIDEO\",\"media_url\":\"$27\",\"permalink\":\"https://www.instagram.com/reel/DXVtz2HEXS6/\",\"timestamp\":\"2026-04-20T04:01:44+0000\"},{\"id\":\"18149109307479236\",\"caption\":\"這裡是南竿清水村，一個轉角，三種世界\\n👈 #清水境白馬尊王廟 保平安🙏 \\n👉熱血球場揮撒汗水🏀 \\n👆生態濕地看海景🦀\\n\\n這麼別緻特殊的景觀，下次不妨經過停下來欣賞看看😎\",\"media_type\":\"CAROUSEL_ALBUM\",\"media_url\":\"https://scontent-tpe1-1.cdninstagram.com/v/t39.30808-6/672370226_1417714370373513_8529475009185392052_n.jpg?stp=dst-jpg_e35_tt6\u0026_nc_cat=106\u0026ccb=7-5\u0026_nc_sid=18de74\u0026efg=eyJlZmdfdGFnIjoiQ0FST1VTRUxfSVRFTS5iZXN0X2ltYWdlX3VybGdlbi5DMyJ9\u0026_nc_ohc=-QTGR66le5EQ7kNvwHtmu8B\u0026_nc_oc=Adrhy6Fnt4SACKMHpukPeEqFzPyEcl9KfhmyjWDSTjtRsCqboy31ARufa3w1FMInQXY\u0026_nc_zt=23\u0026_nc_ht=scontent-tpe1-1.cdninstagram.com\u0026edm=AM6HXa8EAAAA\u0026_nc_gid=kOJ_3WJcVRFTwljiOtsy4A\u0026oh=00_Af1RIMUIIdta7IwudWNKkQGgi3fefdnJUnbbRnapN1i9Jg\u0026oe=69F23991\",\"permalink\":\"https://www.instagram.com/p/DXTI_YIDjbn/\",\"timestamp\":\"2026-04-19T04:00:53+0000\"},{\"id\":\"18035744216625935\",\"caption\":\"來馬祖沒吃過 #地瓜餃，別說你來過！ \\n這顆金黃色、三角形像元寶一樣的小東西\\n可是馬祖人從小吃到大的甜蜜回憶💛\\n外皮是用地瓜揉成的\\n內餡從花生、芝麻到肉末、香蔥都有\\n一口咬下香氣四溢😋\\n\\n地瓜餃主要有兩種吃法\\n🔥#炸派 炸得金黃酥脆\\n熱熱的糖漿流出來，邪惡度爆表😈\\n🥣#湯派 蒸完搭配甜湯或加在冰品上\\n吸飽甜湯汁的外皮變得更軟糯滑順🥰\\n\\n快在底下留言告訴小編：你是炸派還是湯派？\\n#馬祖美食\",\"media_type\":\"VIDEO\",\"media_url\":\"$28\",\"permalink\":\"https://www.instagram.com/reel/DXI2QN2E-dL/\",\"timestamp\":\"2026-04-15T04:06:00+0000\"},{\"id\":\"17902928595246124\",\"caption\":\"一路向下通往曾經是南竿第二大村 #津沙\\n這裡的美值得細細品嚐🫰🏽\\n\\n早年這裡漁產興盛不只有漁船\\n還有釀酒坊、藥鋪、商號\\n甚至還有煙館，村裡還設有私塾\\n\\n走在聚落裡\\n還有一個絕對不能錯過的亮點 #津沙境天后宮\\n這裡供奉著全馬祖唯一的 #黑面媽祖🙏\\n相傳早年的津沙媽祖原本也是常見的粉面\\n但在某次廟宇重建時，負責雕塑的師傅居然夢見媽祖顯靈\\n並以「黑面」的法相託夢，經過向村裡長老請示\\n大家決定遵從神意\\n於是造就了這尊全馬祖獨一無二的黑面媽祖🫡\\n\\n這尊充滿傳奇色彩的媽祖娘娘\\n長年伴隨著鼎盛的香火與海風\\n至今依然溫柔地守護著這座村落的起落與每一位旅人\\n雖然歷經了戰火（日軍曾據守在此控制航道）\\n也見證了漁場的沒落\\n現在的津沙在縣政府與社區的努力下\\n閩東式老屋變身成了風格民宿與老酒館🙌🏼\\n\\n有機會來這裡點一杯特調\\n敬這個曾經繁華、如今優雅重生的魅力小鎮吧🥂\\n#馬祖旅遊 #津沙聚落\",\"media_type\":\"CAROUSEL_ALBUM\",\"media_url\":\"https://scontent-tpe1-1.cdninstagram.com/v/t51.82787-15/669907462_18112064110769321_1959559104807371668_n.jpg?stp=dst-jpg_e35_tt6\u0026_nc_cat=111\u0026ccb=7-5\u0026_nc_sid=18de74\u0026efg=eyJlZmdfdGFnIjoiQ0FST1VTRUxfSVRFTS5iZXN0X2ltYWdlX3VybGdlbi5DMyJ9\u0026_nc_ohc=oChnzJLoZugQ7kNvwFbs5Aj\u0026_nc_oc=Adq9AiY6hXgFKq2s6JihN1BHKz-P2TBmkp-gN3P2uj8Xey1hv2vLJS9P2PSm8k68Urs\u0026_nc_zt=23\u0026_nc_ht=scontent-tpe1-1.cdninstagram.com\u0026edm=AM6HXa8EAAAA\u0026_nc_gid=kOJ_3WJcVRFTwljiOtsy4A\u0026oh=00_Af1fzsZc1kHPMM3IzbTlne-dcQJ3vEJrBz_nDk9AnuC2xg\u0026oe=69F2333D\",\"permalink\":\"https://www.instagram.com/p/DXDsLbME3Bk/\",\"timestamp\":\"2026-04-13T04:00:02+0000\"},{\"id\":\"17932275045248687\",\"caption\":\"來馬祖追 #藍眼淚\\n最怕遇到淚況不好或海風太大\\n不適合帶小朋友去海邊吹風～\\n別擔心！小編要把這個100%成功率的秘密基地推薦給你\\n#南竿藍眼淚生態館！\\n館內透過專業的培育技術\\n讓你在室內就能近距離看見夢幻的藍光💙\\n\\n1️⃣互動超好玩：不只能看，還能動手玩！拿著滴管撥動培養皿，藍眼淚就會像魔法一樣亮起！\\n2️⃣科普長知識：這裡有專業導覽員解說，告訴你藍眼淚的小秘密，寓教於樂！\\n3️⃣光影環繞體驗：除了看實體，還有沉浸式的影片介紹，帶你認識馬祖的生態之美。\\n\\n不妨帶孩子來生態館，上一堂最夢幻的自然科學課吧！\\n📍地點： 南竿藍眼淚生態館 \\n⚠️小提醒： 每一場次有人數限制，建議提前預約喔！\\n#小編整個為之驚艷\\n#超美啦\",\"media_type\":\"VIDEO\",\"media_url\":\"$29\",\"permalink\":\"https://www.instagram.com/reel/DW-is70jLAT/\",\"timestamp\":\"2026-04-11T04:02:00+0000\"},{\"id\":\"17999256143748228\",\"caption\":\"在 #馬祖南竿，有一座獨立在海上的堡壘\\n這裡曾經是防禦最前線，還配置軍犬防衛，是當時防區唯一有軍階的軍犬🐶\\n📍為什麼叫 #鐵堡：因爲它就像是一座鋼鐵般的堡壘，傲然屹立在狂風巨浪中。 這裡原是一座獨立的岩礁，國軍弟兄將內部鑿空，在裡面建了坑道、射口、砲台、房間，甚至還有廚房和廁所！麻雀雖小，五臟俱全，完全是海上的變形金剛🤖\\n👻水鬼與軍犬：因為地形特殊，以前這裡是「水鬼」最常摸哨的地方。\\n為了防範夜襲，當時特別飼養了受過嚴格訓練的軍犬駐守。\\n下次來南竿，別忘了來這裡見證歷史🤓\\n\\n#馬祖旅遊 #馬祖景點\",\"media_type\":\"VIDEO\",\"media_url\":\"$2a\",\"permalink\":\"https://www.instagram.com/reel/DW0PHSNDhIj/\",\"timestamp\":\"2026-04-07T03:58:21+0000\"},{\"id\":\"18091272508916647\",\"caption\":\"各角度帶大家看馬祖的守護神 #媽祖巨神像\\n連假的第一站，小編強烈推薦來南竿馬港\\n沿著祈福步道，登上這座守護島嶼的媽祖巨神像\\n站在造型像一艘大船的觀景平台上\\n看著媽祖娘娘慈悲地望向大海，彷彿正乘風破浪，庇佑著每一位居民與旅人🌊\\n這座歷時 10 年以上才完工的宏偉地標，其實藏著滿滿的細節與故事！\\n1️⃣整座神像由365塊花崗岩堆砌雕琢而成，象徵著「365 日、日日平安」❤️\\n2️⃣巨神像本體高度為 28.8 公尺。這個數字最初是為了呼應馬祖四鄉五島的總面積 28.8 平方公里，後來經過最新測量，發現馬祖實際面積其實是 29.6 平方公里！為了讓這份守護更加精確，建造時特別加上了避雷針，讓總高度剛好達到 29.6 公尺！ \\n是不是超級用心😲\\n最後還有祈福坑道，連假來這裡走走，祈求旅程平安順利喔！\\n#馬祖旅遊 #馬祖\",\"media_type\":\"VIDEO\",\"media_url\":\"$2b\",\"permalink\":\"https://www.instagram.com/reel/DWvF383Ce_a/\",\"timestamp\":\"2026-04-05T04:01:30+0000\"},{\"id\":\"18427304038185274\",\"caption\":\"#馬祖好玩到超乎想像\\n別眨眼\\n這不是大家印象中的馬祖🧐\\n這是馬祖的節奏\\n狂野、絕美、超乎想像✨\\n準備好跟上了\\n來一場獨特的馬祖之旅吧🙌\\n#馬祖 #Matsu #馬祖旅遊\",\"media_type\":\"VIDEO\",\"media_url\":\"$2c\",\"permalink\":\"https://www.instagram.com/reel/DWiN67CCY9O/\",\"timestamp\":\"2026-03-31T04:01:41+0000\"},{\"id\":\"17955300075111096\",\"caption\":\"三月底，隨著南風漸起\\n馬祖的海邊開始不一樣了～\\n\\n#藍眼淚是什麼\\n它們是 #夜光藻，一群隨著海流漂泊的微小生物，當夜光藻感應到海浪的拍打或岩石的撞擊時，就會發出淡藍色的螢光，像是在漆黑的海面上撒下整片銀河🌌\\n雖然藍眼淚一年四季都存在，但只有在春夏交替（4月-6月）水溫回暖時，因為大量繁殖，才會形成我們肉眼可見的絕美奇觀。\\n\\n現在，這場年度限定的 #藍色派對 正在悄悄暖身中 \\n今年的第一滴淚，你會在哪個沙灘遇見呢？\\n\\n#追淚小叮嚀 想拍美照，請大家務必遵守\\n🚫不要亂丟石頭：石頭會破壞生態也危險！\\n⚠️注意腳下安全：夜晚視線暗，岸邊濕滑，請一定要結伴同行，安全第一。\\n\\n🌲附上小編去年瘋狂拍打海面拍出來的藍眼淚樹🌲😍\\n\\n留言和我們分享你們的藍眼淚美照！\",\"media_type\":\"IMAGE\",\"media_url\":\"https://scontent-tpe1-1.cdninstagram.com/v/t39.30808-6/657331934_1398028772342073_7641193176027597941_n.jpg?stp=dst-jpg_e35_tt6\u0026_nc_cat=105\u0026ccb=7-5\u0026_nc_sid=18de74\u0026efg=eyJlZmdfdGFnIjoiRkVFRC5iZXN0X2ltYWdlX3VybGdlbi5DMyJ9\u0026_nc_ohc=FqB52QyyjCEQ7kNvwFCCbAm\u0026_nc_oc=Adp9JT9L1tCykrVOmvBbUZaiIpoAUcQAUrz-e5sj7KCiK4y0yZohhhvVVBEfPrUOn6E\u0026_nc_zt=23\u0026_nc_ht=scontent-tpe1-1.cdninstagram.com\u0026edm=AM6HXa8EAAAA\u0026_nc_gid=kOJ_3WJcVRFTwljiOtsy4A\u0026oh=00_Af3l4WxVrwwXgNKrL6JtKNUDsKYJmcYZ1fzhwIG__shx2Q\u0026oe=69F22F45\",\"permalink\":\"https://www.instagram.com/p/DWfpEF6Dd6I/\",\"timestamp\":\"2026-03-30T04:00:39+0000\"},{\"id\":\"17861216625655092\",\"caption\":\"#2026馬祖擺暝文化祭\\n擺暝雖然結束了，但那晚的震撼還留在心裡吧？ \\n燒馬糧的熱浪、炸轎的煙硝、還有神轎劇烈搖晃的力度💪\\n帶你重回那個的瘋狂夜晚🌌\\n還沒看過馬祖擺暝的朋友\\n點開影片，你就知道明年為什麼一定要來了！\\n明年，我們馬祖見🔥\",\"media_type\":\"VIDEO\",\"media_url\":\"$2d\",\"permalink\":\"https://www.instagram.com/reel/DWafjSeD4Un/\",\"timestamp\":\"2026-03-28T04:01:50+0000\"},{\"id\":\"18100942948941068\",\"caption\":\"來到南竿，經過清水與珠螺之間，你一定會看到這座延伸入海的 #勝利堡\\n它不只是一座碉堡，它曾是南竿防區的 #01據點\\n扼守著東西莒與南竿之間的門戶，地理位置超級重要👍\\n現在這裡已經卸下武裝，變身為 #戰地文化博物館 \\n不同於其他據點只有冷冰冰的砲台，勝利堡裡面展示了滿滿的人味🫰🏽\\n當年阿兵哥的家書、泛黃的老照片、軍用罐頭與榮譽證🥫✉️\\n走進這裡，不像是參觀景點，更像是走進了一段屬於那個年代的青春歲月✨\\n想看懂馬祖的戰地故事？先來勝利堡報到🤓\\n\\n📍馬祖南竿勝利堡\\n✦開館時間：09:00-16:30\\n✦休館日：每週四休館\\n✦免費入場\",\"media_type\":\"VIDEO\",\"media_url\":\"$2e\",\"permalink\":\"https://www.instagram.com/reel/DWVV70Sj09k/\",\"timestamp\":\"2026-03-26T04:01:35+0000\"},{\"id\":\"17861614098543719\",\"caption\":\"今年的 #北竿硬地馬拉松，依然是那個沒有在跟我們客氣的 #全台最硬賽道🏃‍➡️\\n雖然今天的天氣有點濕冷，海風吹過來還真的會讓人打個冷顫🧣\\n但看到大家在賽道上咬牙堅持的模樣，真的只有佩服兩個字可以形容！💪\\n\\n一樣是上坡跑到懷疑人生，下坡煞車煞到腳趾發抖（小編看到很多不同的下坡跑法太強啦！）\\n但也正因為這份艱辛，沿途的風景才美得更加刻骨銘心🌟\\n在雙腿最沉重、最痛苦的時候遇見最美的北竿景色，這絕對就是傳說中的「痛並快樂著」吧！\\n不管最後成績如何，能在這種濕冷天氣下成功挑戰這條魔王級賽道，你們就已經徹底贏了自己🏆\\n\\n小編先雙手奉上今天熱騰騰的幾張賽事精華📸\\n更多照片期待明日貼文😍\\n\\n👇 #跑友簽到處👇和我們分享哪一段跑的最新辛苦！\",\"media_type\":\"CAROUSEL_ALBUM\",\"media_url\":\"https://scontent-tpe1-1.cdninstagram.com/v/t51.82787-15/655220917_18109832809769321_2842794704626815985_n.jpg?stp=dst-jpg_e35_tt6\u0026_nc_cat=100\u0026ccb=7-5\u0026_nc_sid=18de74\u0026efg=eyJlZmdfdGFnIjoiQ0FST1VTRUxfSVRFTS5iZXN0X2ltYWdlX3VybGdlbi5DMyJ9\u0026_nc_ohc=uxLvxl27EYAQ7kNvwGujfZd\u0026_nc_oc=Adr5iD727GUEEND_bgn-ip4mTYBatuSvtj88V7CK-1t6gFnqM67xmqHSo__uZqF0itE\u0026_nc_zt=23\u0026_nc_ht=scontent-tpe1-1.cdninstagram.com\u0026edm=AM6HXa8EAAAA\u0026_nc_gid=kOJ_3WJcVRFTwljiOtsy4A\u0026oh=00_Af0T2F8sJkNonrPOK5MXvBIvBq48D6raQf0C-sd-fufq9w\u0026oe=69F249E4\",\"permalink\":\"https://www.instagram.com/p/DWJYJZVk1C_/\",\"timestamp\":\"2026-03-21T12:29:32+0000\"},{\"id\":\"18087198953185033\",\"caption\":\"#小編真心推薦\\n來 #東引，一定要租台機車，享受一下這裡的 #公路旅行🏍️\\n騎在東引的公路上，那感覺真的很不一樣，是一種與世無爭的感覺😇\\n才剛爬過一個超陡的長坡，映入眼簾的就是360度無死角的無敵海景✨\\n風很大、陽光很烈、海很藍，這就是東引才有的自由味道！\\n來這裡，不要只看景點，路本身就是最美的風景🙌\\n#留言跟我分享你們的東引美景\",\"media_type\":\"VIDEO\",\"media_url\":\"$2f\",\"permalink\":\"https://www.instagram.com/reel/DWAvjHaAMUe/\",\"timestamp\":\"2026-03-18T04:01:22+0000\"},{\"id\":\"18169107775403116\",\"caption\":\"農曆正月二十九來到北竿 #祈夢 現場\\n擺暝的最後高潮，不是狂歡，而是沈澱✨\\n北竿的祈夢儀式，只要帶著虔誠的心來到廟裡，向神明稟報你的生辰八字與困惑，然後在神明座前睡上一覺，心中的結就有機會在夢中解開👐\\n這裡是祈夢的現場，沒有手機的藍光，只有繚繞的香火～\\n我們把疑惑交給神明，把身體交給大地。\\n休息一下，人生的答案也許就會浮現💡\\n📍 地點：北竿龍角峰伍靈公廟\\n#照片有祈夢流程\\n\\n大家都會做夢嗎！夢到什麼～歡迎留言和小編分享🙌\",\"media_type\":\"CAROUSEL_ALBUM\",\"media_url\":\"https://scontent-tpe1-1.cdninstagram.com/v/t39.30808-6/651208509_1392190529592564_8167967686715505025_n.jpg?stp=dst-jpg_e35_tt6\u0026_nc_cat=102\u0026ccb=7-5\u0026_nc_sid=18de74\u0026efg=eyJlZmdfdGFnIjoiQ0FST1VTRUxfSVRFTS5iZXN0X2ltYWdlX3VybGdlbi5DMyJ9\u0026_nc_ohc=PjqOqYEMq_gQ7kNvwFjV-hJ\u0026_nc_oc=Adq-vVr6TZFN4dzq4S_lyp7asOkyG85cvpD_CFfBRzYQSdU9YLl1FGabcQCanL-DRX0\u0026_nc_zt=23\u0026_nc_ht=scontent-tpe1-1.cdninstagram.com\u0026edm=AM6HXa8EAAAA\u0026_nc_gid=kOJ_3WJcVRFTwljiOtsy4A\u0026oh=00_Af2baKwYU-_vzTpls-1SD46fRjASkY2S8CuinFTVdhTY4Q\u0026oe=69F2442E\",\"permalink\":\"https://www.instagram.com/p/DV-zFdDCURj/\",\"timestamp\":\"2026-03-17T09:53:16+0000\"},{\"id\":\"17999776259874218\",\"caption\":\"#沈浸式南竿勝利水庫 #聽自然的聲音🎧\\n還記得前陣子分享的 #馬祖民俗文物館 嗎？ \\n很多人在館內吸收完滿滿的歷史知識後，腦袋可能有點飽和了😆\\n這時候只要走出大門往前方一看，眼前這片開闊的景色絕對能讓你深呼吸一口氣！ \\n這裡是南竿最大的淡水蓄水區 #勝利水庫💧\\n雖然它名為水庫，但看起來更像是一座被群山環抱的靜謐湖泊。 \\n深綠色的水面配上周圍茂密的樹林，讓這裡的空氣多了一份清幽與寧靜。\\n逛完展覽，站在這裡吹吹風、看看寬廣的湖景，剛好讓思緒沉澱一下，轉換心情繼續接下來的旅程🍃\",\"media_type\":\"VIDEO\",\"media_url\":\"$30\",\"permalink\":\"https://www.instagram.com/reel/DV5BR4fglYJ/\",\"timestamp\":\"2026-03-15T04:02:18+0000\"},{\"id\":\"18061157927352581\",\"caption\":\"#芹壁巷弄連發♥\\n來到北竿芹壁，請先把導航關掉～\\n這裡的房子依山而建，層層疊疊的花崗岩石頭屋，構築成一座最美的山城迷宮😍\\n你永遠不知道，沿著這條蜿蜒的石階往上走，轉個彎會遇見什麼？ \\n也許是一隻慵懶曬太陽的橘貓 🐈 \\n也許是牆上斑駁卻充滿時代感的「精神標語」🪧 \\n又或者是一個視角絕佳的露台，讓你一抬頭就撞見蔚藍大海與可愛的龜島 🐢\\n在芹壁的巷弄裡，時間走得很慢💫\\n石牆上映著光影的變化，海風穿過窄巷的聲音，都在告訴你：「慢下來，這裡適合發呆。」\\n#馬祖 #北竿 #芹壁 #閩東建築\",\"media_type\":\"CAROUSEL_ALBUM\",\"media_url\":\"https://scontent-tpe1-1.cdninstagram.com/v/t39.30808-6/650363875_1387994190012198_5090329760077878114_n.jpg?stp=dst-jpg_e35_tt6\u0026_nc_cat=103\u0026ccb=7-5\u0026_nc_sid=18de74\u0026efg=eyJlZmdfdGFnIjoiQ0FST1VTRUxfSVRFTS5iZXN0X2ltYWdlX3VybGdlbi5DMyJ9\u0026_nc_ohc=alu814OEs_gQ7kNvwFC_hgp\u0026_nc_oc=AdoeAP3Xo_39Qw0mnco4mOFbPKFb1wdwuOpAkU51b82eZ18OQk5J26gq2iu-AM5pPdQ\u0026_nc_zt=23\u0026_nc_ht=scontent-tpe1-1.cdninstagram.com\u0026edm=AM6HXa8EAAAA\u0026_nc_gid=kOJ_3WJcVRFTwljiOtsy4A\u0026oh=00_Af0DpomW__P6ztet5sKXqRVN8Vhqw7xL4FSOBJV661prhQ\u0026oe=69F23EAA\",\"permalink\":\"https://www.instagram.com/p/DVz3jn4iu2u/\",\"timestamp\":\"2026-03-13T04:00:42+0000\"},{\"id\":\"18572980837063856\",\"caption\":\"漫步在馬祖的聚落或參拜廟宇時，你是否注意過兩側那高聳誇張、線條極具張力的牆垣？\\n這就是閩東建築中，最讓人印象深刻的標誌 #封火山牆 💥\\n\\n牆蓋得比屋頂還高，其實這藏著先民的防災智慧，早期的聚落多為木造建築，且房屋棟距緊密，為了避免火災發生時「火燒連環船」，特別將側牆築高，用來阻隔火勢蔓延，因此得名「封火」。\\n\\n不同於台灣本島常見的馬背或燕尾，馬祖的封火山牆線條更為飛揚、狂放，依照風水五行，其實有金、木、水、火、土不同的造型，而在馬祖的廟宇中，最常見的是如火焰般尖聳的「火形」，以及如波浪般圓融的「水形」，既展現了神威顯赫，也寄託了防火祈安的寓意。\\n\\n如今，這些原本為了防災而生的牆垣，已成為馬祖天際線上最美的風景。 \\n下次來馬祖旅遊時，不妨抬頭找找看，來收集不同造型的封火山牆📸\\n#馬祖 #Matsu #閩東建築 #封火山牆 #建築美學 #廟宇文化\",\"media_type\":\"CAROUSEL_ALBUM\",\"media_url\":\"https://scontent-tpe1-1.cdninstagram.com/v/t39.30808-6/648870722_1385589686919315_4362495354188885547_n.jpg?stp=dst-jpg_e35_tt6\u0026_nc_cat=106\u0026ccb=7-5\u0026_nc_sid=18de74\u0026efg=eyJlZmdfdGFnIjoiQ0FST1VTRUxfSVRFTS5iZXN0X2ltYWdlX3VybGdlbi5DMyJ9\u0026_nc_ohc=3ya1F6Bv4uEQ7kNvwGjOZYR\u0026_nc_oc=Adqt_H5x-p7_h1XZVHCKAg1NvG8I9ADQR1S6-2Ta8s_NusDej1d4levJOUH3arJDZ74\u0026_nc_zt=23\u0026_nc_ht=scontent-tpe1-1.cdninstagram.com\u0026edm=AM6HXa8EAAAA\u0026_nc_gid=kOJ_3WJcVRFTwljiOtsy4A\u0026oh=00_Af1jcwj994C0e54uLahb2McK8zQQbWZdy44gHkvRyNGHNg\u0026oe=69F23A09\",\"permalink\":\"https://www.instagram.com/p/DVpkXlaApDS/\",\"timestamp\":\"2026-03-09T04:00:38+0000\"},{\"id\":\"17996902034870817\",\"caption\":\"#馬祖魚餃\\n製作馬祖手工魚餃得先將新鮮魚肉剔骨取肉，不斷拍打、搓揉直到出筋，才能桿出這一張張薄如蟬翼、卻又韌性十足的「魚麵皮」。\\n再包入調味好的新鮮絞肉送入蒸籠，隨著蒸氣上升，魚皮會慢慢變得晶瑩剔透。\\n剛出爐的魚餃，外皮那股鮮味被緊緊鎖住，吃起來又Q又脆，配上裡頭多汁的肉餡，這就是馬祖人最道地的海味下午茶🥟\\n這顆魚餃，皮是海鮮、餡是山珍，一口咬下，山海的精華在嘴裡爆發🌊\\n這是馬祖人手掌心的溫度，也是我們從小吃到大的奢華美味。\\n你看這透亮的光澤，是不是很想咬一口？😋來馬祖嚐嚐看吧！\\n#馬祖美食 #手工魚餃\",\"media_type\":\"VIDEO\",\"media_url\":\"$31\",\"permalink\":\"https://www.instagram.com/reel/DVkazIrCD7C/\",\"timestamp\":\"2026-03-07T04:01:24+0000\"},{\"id\":\"17993812241755080\",\"caption\":\"#元宵節，現在的馬祖，鼓板聲響徹雲霄🥁\\n今晚是農曆正月十五，也是馬祖擺暝最熱鬧的時刻，也是馬祖人真正的過年💥\\n遶境隊伍正浩浩蕩蕩地穿梭在四鄉五島街區之中，漫天的煙火與鞭炮聲中，你看得見乩轎的神威擺動、香陣的虔誠隨行，這不只是一場繞境，更是一場「神與神的鏈結」！ \\n各境神明透過這場巡禮，彼此問候、共同守護這座島嶼，那種神氣與人氣交織的震撼，真的會讓人起雞皮疙瘩！不管你現在是在隊伍中，還是在路邊圍觀，今晚，我們都是這場神聖慶典的一部分！🔥\\n\\n祝福看完影片的各位，平安健康♥\\n#擺暝文化祭 #遶境祈福\",\"media_type\":\"VIDEO\",\"media_url\":\"$32\",\"permalink\":\"https://www.instagram.com/reel/DVbJhyNDoHL/\",\"timestamp\":\"2026-03-03T13:37:12+0000\"},{\"id\":\"18129956140533737\",\"caption\":\"#2026馬祖擺暝文化祭\\n回顧3月1日的南竿梅石藝文中心《#四郎探母》的鑼鼓聲落下，但心裡的震撼還在迴盪。\\n因為 #鐵甲元帥 親自降旨「點戲」，由北竿在地素人鄉親組成的「御甲戲園」與「國光劇團」攜手，歷經近一年的嚴格苦練，終於淬鍊出超水準的演出！\\n\\n二月在本島登台，充滿生命力的張力讓眾人在台下熱淚盈眶🥹\\n「這麼好的戲，南竿鄉親也一定要看到！」 \\n經請示後，元帥霸氣答應了，促成了這場南竿加演！\\n\\n謝謝昨天參與這場盛宴的每一位，完成了一場美好的「元帥點戲」，也為擺暝文化祭更增色彩💥\\n快在底下為他們掌聲鼓勵👏👏👏\",\"media_type\":\"CAROUSEL_ALBUM\",\"media_url\":\"https://scontent-tpe1-1.cdninstagram.com/v/t39.30808-6/641548857_1380086960802921_6687986733452084959_n.jpg?stp=dst-jpg_e35_tt6\u0026_nc_cat=101\u0026ccb=7-5\u0026_nc_sid=18de74\u0026efg=eyJlZmdfdGFnIjoiQ0FST1VTRUxfSVRFTS5iZXN0X2ltYWdlX3VybGdlbi5DMyJ9\u0026_nc_ohc=fxWccL7h4GAQ7kNvwGxRIm-\u0026_nc_oc=AdqJuRMFa7nPFdM_MHN1uz2xopH4vya-kPPVlMAvOjL4IZQeN_eqRikGzQFLqZci9co\u0026_nc_zt=23\u0026_nc_ht=scontent-tpe1-1.cdninstagram.com\u0026edm=AM6HXa8EAAAA\u0026_nc_gid=kOJ_3WJcVRFTwljiOtsy4A\u0026oh=00_Af2zRH6nNxjWfSFulrBXWpj7xpo5ZXL90a8i-SbdWY6wvA\u0026oe=69F25914\",\"permalink\":\"https://www.instagram.com/p/DVXiw5oAVr1/\",\"timestamp\":\"2026-03-02T04:00:17+0000\"},{\"id\":\"18059497301346251\",\"caption\":\"#2026馬祖擺暝文化祭 \\n正月十三，熱騰騰的 #燒馬糧 現場來啦，真的太熱血了🔥\\n成堆的糧草、響徹雲霄的鑼鼓聲，還有大煙火💥\\n大家在火光中專注祈福的臉龐，這就是馬祖擺暝最迷人的魅力！\\n看著糧草化作火光直衝天際，相信白馬尊王與祂的座騎一定感受到了大家的滿滿心意。\\n有了神馬吃飽喝足的守護，相信新的一年，我們一定都能順順利利、平安健康！\\n錯過的朋友別難過，我們約好明年見👋\\n#馬祖\",\"media_type\":\"VIDEO\",\"media_url\":\"$33\",\"permalink\":\"https://www.instagram.com/reel/DVWGgqxAKTT/\",\"timestamp\":\"2026-03-01T14:34:39+0000\"},{\"id\":\"18106946908761182\",\"caption\":\"#2026馬祖擺暝文化祭 \\n直擊 #祭祀大典 現場，敬天謝地鐵甲護佑🙏\\n今天一早，芹壁天后宮的鐘鼓聲響起，一年一度的「祭祀大典」隆重登場🔥\\n在馬祖，擺暝不只是熱鬧的鞭炮聲，更多的是我們對神明最深的敬意\\n在主祭官引領下依循古禮，向輪值主辦的「鐵甲元帥」（蛙神）及眾神明獻上最虔誠的祝禱\\n祈求這座島嶼在馬年能風調雨順，每一位鄉親都能平安順遂\\n願鐵甲元帥的神威，護佑大家一整年！🐸✨\\n#擺暝文化祭 #祭祀大典 #芹壁 #鐵甲元帥 #祈福\",\"media_type\":\"VIDEO\",\"media_url\":\"$34\",\"permalink\":\"https://www.instagram.com/reel/DVStyglFA-p/\",\"timestamp\":\"2026-02-28T07:00:51+0000\"},{\"id\":\"17940192828156172\",\"caption\":\"#2026擺暝文化祭，今晚開幕點燈🔥\\n今晚點燈儀式啟動，象徵神明正式發出邀請函\\n不管你是來看熱鬧的、來求平安的，還是來拍大片的\\n接下來一直到3月中，馬祖絕對讓你玩到不想回家！\\n\\n快告訴我，你最期待哪一場活動？ \\n是京劇？燒馬糧？還是元宵當晚的繞境？\\n擺暝的號角響起了，大家跟上🧨🧨🧨\\n🐸北竿芹壁滿滿的蛙神在迎接你喔🐸\\n\\n#影片最後的煙火太狂了\\n#馬祖 #擺暝文化祭 #芹壁 #鐵甲元帥 #青蛙神 #北竿\",\"media_type\":\"VIDEO\",\"media_url\":\"$35\",\"permalink\":\"https://www.instagram.com/reel/DVQzHZugoHD/\",\"timestamp\":\"2026-02-27T13:09:09+0000\"}]}]]\n"])</script></body></html>